{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "教材工房",
  "version": "0.1.0",
  "identifier": "com.ryoma.kyozai-kobo",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "教材工房",
        "width": 1360,
        "height": 860,
        "minWidth": 960,
        "minHeight": 600,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$TEMP/kyozai-kobo-build/**", "$APPDATA/ai_jobs/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
